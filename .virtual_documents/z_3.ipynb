


import pandas as pd
import matplotlib.pyplot as plt
from matplotlib.backends.backend_pdf import PdfPages

df = pd.read_csv('output_z/sales_transactions_cleaned.csv')
df['date'] = pd.to_datetime(df['date']).dt.strftime('%Y-%m')
df['rev'] = df.quantity * df.price - pd.to_numeric(df.discount_amount, errors='coerce').fillna(0)

m = df.groupby('date').agg(rev = ('rev', 'sum'), tx = ('transaction_id', 'nunique')).reset_index()
m['aov'] = m.rev / m.tx

top3 = m.nlargest(3, 'rev').assign(rev = lambda x: x.rev.map('${:,.2f}'.format))

with PdfPages('output_z/Session1_SalesTrends.pdf') as pdf:
    for col, color, title in [('rev', 'red', 'Total Revenue'), ('tx', 'blue', 'Number of transactions per month'), ('aov', 'orange', 'Average order value per month')]:
        fig, ax = plt.subplots(figsize = (12, 5))
        ax.plot(m['date'], m[col], marker='D', color=color)
        ax.set_title(title, weight='bold')
        ax.tick_params(axis='x', rotation=45)
        ax.grid(ls='--', alpha=0.5)
        pdf.savefig(fig, bbox_inches='tight'); plt.close()

    # table
    fig, ax = plt.subplots(figsize=(12, 2)); ax.axis('off')
    tbl = ax.table(cellText=top3[['date', 'rev']].values, colLabels = ['Month', 'Rev'], loc='center', cellLoc='center')
    tbl.scale(1, 2)

    for c in range(2):
        tbl[0, c].set_facecolor('blue')
        tbl[0, c].set_text_props(color='white', weight='bold')

    pdf.savefig(fig, bbox_inches='tight'); plt.close()

